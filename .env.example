# .env.example — Template public des variables d'environnement
#
# Copie ce fichier en .env et remplis les valeurs.
# Ce fichier PEUT être commité : il ne contient aucune valeur sensible.

# ─── Anthropic (Claude) ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Notion ───────────────────────────────────────────────────────────────────
NOTION_API_KEY=secret_...
NOTION_DATABASE_ID=

# ─── Google ───────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── YouTube Data API ─────────────────────────────────────────────────────────
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# ─── Vercel ───────────────────────────────────────────────────────────────────
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# ─── GitHub ───────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_USERNAME=

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
